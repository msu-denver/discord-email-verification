# ===========================================
# Discord Email Verification Bot Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# --- Discord Configuration ---
# Bot token from the Discord Developer Portal (Bot > Token)
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord server (guild) ID
SERVER_ID=your_server_id_here

# Role IDs (right-click role in Discord with Developer Mode enabled)
QUARANTINE_ROLE_ID=your_quarantine_role_id
VERIFIED_ROLE_ID=your_verified_role_id
ADMIN_ROLE_ID=your_admin_role_id

# Channel IDs (right-click channel in Discord with Developer Mode enabled)
VERIFICATION_CHANNEL_ID=your_verification_channel_id
WELCOME_CHANNEL_ID=your_welcome_channel_id

# Server display name (used in emails and messages)
SERVER_NAME=CyberBridge

# --- AWS SES Email Configuration ---
# The verified sender email address in Amazon SES
SES_FROM_EMAIL=verification@yourdomain.edu
SES_FROM_NAME=CyberBridge Discord Verification

# AWS region for SES and DynamoDB
AWS_REGION=us-east-1

# LocalStack endpoint for local development (remove for production)
# Start LocalStack with: docker compose up -d
# AWS_ENDPOINT_URL=http://localhost:4566

# --- Storage Configuration ---
# Set to "true" to use local file storage instead of DynamoDB (for development)
USE_LOCAL_STORAGE=false

# DynamoDB table name (only needed if USE_LOCAL_STORAGE=false)
DYNAMODB_TABLE_NAME=discord-verification
