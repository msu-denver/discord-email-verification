{
  "name": "@msu-denver/discord-email-verification",
  "version": "1.0.0",
  "description": "Discord bot for email-based server verification (MSU Denver CyberBridge)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --omit=dev --audit-level=high"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "discord",
    "bot",
    "email",
    "verification",
    "msu-denver"
  ],
  "author": "MSU Denver CyberBridge",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1038.0",
    "@aws-sdk/client-ses": "^3.1038.0",
    "@aws-sdk/lib-dynamodb": "^3.1038.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
